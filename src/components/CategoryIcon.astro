---
// Simple, hand-inked SVG icons — one per skill category. All share a 64x64
// viewBox and stroke="currentColor" so they inherit the surrounding ink color,
// and all get the shared #ink-wobble filter (defined once in Powers.astro) for
// a sketched, not-computer-perfect line quality.
interface Props {
	slug: string;
}

const { slug } = Astro.props;
---

<span class="category-icon">
	{
		slug === 'ai-ml' && (
			<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
				<circle cx="32" cy="14" r="6" />
				<circle cx="14" cy="48" r="6" />
				<circle cx="50" cy="48" r="6" />
				<line x1="32" y1="20" x2="16" y2="43" />
				<line x1="32" y1="20" x2="48" y2="43" />
				<line x1="19" y1="48" x2="45" y2="48" />
			</svg>
		)
	}
	{
		slug === 'document-ai-cv' && (
			<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
				<path d="M4 32c10-16 46-16 56 0-10 16-46 16-56 0Z" />
				<circle cx="32" cy="32" r="8" />
				<line x1="6" y1="32" x2="58" y2="32" stroke-dasharray="3 5" opacity="0.55" />
			</svg>
		)
	}
	{
		slug === 'languages' && (
			<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
				<polyline points="24,14 8,32 24,50" />
				<polyline points="40,14 56,32 40,50" />
			</svg>
		)
	}
	{
		slug === 'web-backend' && (
			<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
				<rect x="10" y="10" width="44" height="12" rx="3" />
				<rect x="10" y="26" width="44" height="12" rx="3" />
				<rect x="10" y="42" width="44" height="12" rx="3" />
				<circle cx="18" cy="16" r="1.6" fill="currentColor" stroke="none" />
				<circle cx="18" cy="32" r="1.6" fill="currentColor" stroke="none" />
				<circle cx="18" cy="48" r="1.6" fill="currentColor" stroke="none" />
			</svg>
		)
	}
	{
		slug === 'tools-platforms' && (
			<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
				<rect x="8" y="26" width="48" height="26" rx="3" />
				<path d="M22 26v-8a4 4 0 0 1 4-4h12a4 4 0 0 1 4 4v8" />
				<line x1="8" y1="38" x2="56" y2="38" />
				<rect x="28" y="34" width="8" height="8" rx="1" />
			</svg>
		)
	}
	{
		slug === 'embedded-systems' && (
			<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
				<rect x="16" y="16" width="32" height="32" rx="3" />
				<line x1="16" y1="24" x2="8" y2="24" />
				<line x1="16" y1="32" x2="8" y2="32" />
				<line x1="16" y1="40" x2="8" y2="40" />
				<line x1="48" y1="24" x2="56" y2="24" />
				<line x1="48" y1="32" x2="56" y2="32" />
				<line x1="48" y1="40" x2="56" y2="40" />
				<line x1="24" y1="16" x2="24" y2="8" />
				<line x1="32" y1="16" x2="32" y2="8" />
				<line x1="40" y1="16" x2="40" y2="8" />
				<line x1="24" y1="48" x2="24" y2="56" />
				<line x1="32" y1="48" x2="32" y2="56" />
				<line x1="40" y1="48" x2="40" y2="56" />
			</svg>
		)
	}
</span>

<style>
	.category-icon {
		display: block;
		width: 100%;
		height: 100%;
		color: var(--color-crimson);
	}

	.category-icon svg {
		width: 100%;
		height: 100%;
		filter: url(#ink-wobble);
	}
</style>
