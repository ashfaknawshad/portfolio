---
import { Image } from 'astro:assets';
import Panel from './Panel.astro';
import type { Project } from '../data/projects';

interface Props {
	project: Project;
	rotate?: number;
	/** Extra attributes (e.g. data-reveal, style with --reveal-i) forwarded to the
	 * card's Panel root. */
	[key: string]: unknown;
}

const { project, rotate = 0, ...rest } = Astro.props;
---

<Panel rotate={rotate} class:list={['card', { 'card--hero': project.isHero }]} {...rest}>
	{
		project.posterImage ? (
			<div class="card__poster card__poster--art">
				<Image
					src={project.posterImage}
					alt={`Movie-poster-style illustration for ${project.name}`}
					widths={[320, 480, 640]}
					sizes="(min-width: 700px) 360px, 90vw"
					loading="lazy"
					class="card__poster-image"
				/>
				<div class="card__poster-masthead" style={`text-align: ${project.posterTitleAlign ?? 'center'};`}>
					<span class="card__genre">{project.poster.genre}</span>
					<p
					class:list={[
						'card__poster-title',
						{ 'card__poster-title--compact': project.posterTitleSize === 'compact' },
					]}
				>
					{project.posterName ?? project.name}
				</p>
				</div>
			</div>
		) : (
			<div class="card__poster">
				<span class="card__genre">{project.poster.genre}</span>
				<p class="card__poster-title">{project.poster.title}</p>
				<p class="card__tagline">"{project.poster.tagline}"</p>
			</div>
		)
	}
	{project.posterImage && <p class="card__tagline card__tagline--below">"{project.poster.tagline}"</p>}

	<div class="card__body">
		<div class="card__heading">
			<h3 class:list={['card__name', { 'card__name--visually-hidden': project.posterImage }]}>
				{project.name}
			</h3>
			{project.isHero && <span class="card__badge card__badge--hero">Flagship</span>}
			{project.status === 'ongoing' && <span class="card__badge card__badge--ongoing">Ongoing</span>}
		</div>

		<p class="card__description">{project.description}</p>

		{
			project.links.length > 0 && (
				<div class="card__links">
					{project.links.map((link) => (
						<a href={link.url} class="card__link" target="_blank" rel="noopener noreferrer">
							{link.label}
						</a>
					))}
				</div>
			)
		}

		<details class="card__cut">
			<summary class="card__cut-toggle">Director's Cut</summary>
			<div class="card__cut-body">
				{project.standoutEngineering && (
					<p class="card__engineering">{project.standoutEngineering}</p>
				)}

				<p class="card__role">{project.role}</p>

				{
					project.contributors && project.contributors.length > 0 && (
						<ul class="card__contributors">
							{project.contributors.map((c) => (
								<li>
									<a href={c.url} target="_blank" rel="noopener noreferrer">
										{c.name}
									</a>
									{' — '}
									{c.role}
								</li>
							))}
						</ul>
					)
				}

				<div class="card__stack">
					{project.techStack.map((tech) => (
						<span class="card__tech">{tech}</span>
					))}
				</div>
			</div>
		</details>
	</div>
</Panel>

<style>
	.card {
		display: flex;
		flex-direction: column;
	}

	.card__poster {
		border: 2px solid var(--color-ink);
		background: var(--color-paper);
		padding: clamp(1.5rem, 4vw, 2rem);
		text-align: center;
		margin-bottom: 1.25rem;
	}

	/* Art variant: the image fills the frame edge-to-edge (no padding/background of
	   its own), with genre + title overlaid on the empty band the generated art
	   leaves at the top — same masthead-over-image pattern as Hero.astro. Unlike the
	   hero (which sits in a forced-dark section over a fixed cream image patch), this
	   card lives in the always-light Issue #3 section, so the normal theme-aware
	   colours already match the image's cream background — no fixed-hex override
	   needed here. */
	.card__poster--art {
		position: relative;
		padding: 0;
		overflow: hidden;
	}

	.card__poster-image {
		display: block;
		width: 100%;
		height: auto;
	}

	.card__poster-masthead {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		padding: clamp(1rem, 7%, 1.75rem) clamp(1rem, 6%, 1.5rem) 0;
	}

	.card__poster--art .card__genre {
		margin-bottom: 0.4rem;
	}

	.card__poster--art .card__poster-title {
		margin: 0;
	}

	.card__tagline--below {
		text-align: center;
		margin-top: -0.5rem;
	}

	.card__genre {
		display: block;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-teal);
		margin-bottom: 0.75rem;
	}

	.card__poster-title {
		font-family: var(--font-display);
		color: var(--color-crimson);
		text-shadow: 0.06em 0.06em 0 var(--color-ink);
		/* Mobile size — larger, since vw-based clamp maxes out well past mobile
		   widths too, so it's reset back down at the 700px breakpoint below. */
		font-size: clamp(2.4rem, 9vw, 2.8rem);
		margin: 0 0 0.5rem;
		line-height: 1.05;
	}

	/* Long two-line titles (e.g. "AI Search Algorithm Visualizer") need the smaller
	   size on mobile to avoid crowding the art underneath. */
	.card__poster-title--compact {
		font-size: clamp(1.6rem, 5vw, 2.2rem);
	}

	@media (min-width: 700px) {
		/* Desktop/tablet: back to the original size — the mobile bump above isn't
		   meant to carry over once the layout has room to breathe. */
		.card__poster-title {
			font-size: clamp(1.8rem, 3vw, 2.2rem);
		}
	}

	.card__tagline {
		font-family: var(--font-body);
		font-style: italic;
		color: var(--color-caption);
		margin: 0;
	}

	.card__heading {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.card__name {
		font-size: 1.3rem;
		margin: 0;
	}

	/* Poster art already carries the real project name in its masthead — kept in the
	   DOM (not display:none) so the heading structure/a11y tree is unaffected, just
	   not shown twice in a row visually. */
	.card__name--visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.card__badge {
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.65rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border-radius: 999px;
		padding: 0.2em 0.65em;
	}

	.card__badge--hero {
		color: var(--color-paper);
		background: var(--color-crimson);
	}

	.card__badge--ongoing {
		color: var(--color-teal);
		border: 1px solid var(--color-teal);
	}

	.card__description {
		font-family: var(--font-body);
		color: var(--color-caption);
		margin: 0 0 1rem;
	}

	.card__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.card__link {
		display: inline-block;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.85rem;
		color: var(--color-ink);
		background: var(--color-paper);
		border: 1.5px solid var(--color-ink);
		border-radius: 0.35em;
		padding: 0.4em 0.85em;
		text-decoration: none;
		transition: transform 0.2s ease, border-color 0.2s ease;
	}

	.card__link:hover {
		transform: scale(1.05);
		border-color: var(--color-crimson);
		color: var(--color-crimson);
	}

	.card__cut {
		border-top: 1px dashed var(--color-rule);
		padding-top: 0.75rem;
	}

	.card__cut-toggle {
		cursor: pointer;
		font-family: var(--font-display);
		letter-spacing: 0.02em;
		color: var(--color-crimson);
		font-size: 1.05rem;
		list-style: none;
	}

	.card__cut-toggle::-webkit-details-marker {
		display: none;
	}

	.card__cut-toggle::before {
		content: '▸ ';
		display: inline-block;
		transition: transform 0.2s ease;
	}

	.card__cut[open] .card__cut-toggle::before {
		transform: rotate(90deg);
	}

	.card__cut-body {
		margin-top: 0.85rem;
	}

	.card__engineering {
		font-family: var(--font-body);
		font-size: 0.92rem;
		color: var(--color-ink);
		margin: 0 0 0.85rem;
	}

	.card__role {
		font-family: var(--font-body);
		font-size: 0.88rem;
		color: var(--color-caption);
		margin: 0 0 0.5rem;
	}

	.card__contributors {
		list-style: none;
		margin: 0 0 0.85rem;
		padding: 0;
		font-family: var(--font-body);
		font-size: 0.85rem;
		color: var(--color-caption);
	}

	.card__contributors a {
		color: var(--color-teal);
	}

	.card__stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.card__tech {
		font-family: var(--font-body);
		font-size: 0.78rem;
		color: var(--color-ink);
		background: var(--color-paper);
		border: 1px solid var(--color-rule);
		border-radius: 0.3em;
		padding: 0.25em 0.55em;
	}

	/* Hero card: more visual weight, per projects.md's request to make SME-GPT
	   the biggest/most prominent card. :global() on .card--hero is required —
	   it's passed as a class prop to <Panel>, so it carries Panel's own scope
	   attribute, not this component's; a plain scoped selector here would never
	   match it (same issue as the earlier hero/Panel integration). */
	:global(.card--hero) .card__poster-title {
		font-size: clamp(2rem, 6vw, 2.75rem);
	}

	:global(.card--hero) .card__name {
		font-size: 1.6rem;
	}

	@media (min-width: 700px) {
		/* :not(.card__poster--art) — the art variant stays edge-to-edge at every
		   breakpoint; this padding is only for the styled-text placeholder poster. */
		:global(.card--hero) .card__poster:not(.card__poster--art) {
			padding: clamp(2rem, 5vw, 3rem);
		}
	}
</style>
