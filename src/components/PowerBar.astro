---
interface Props {
	label: string;
	level: number;
	color?: string;
}

const { label, level, color = 'var(--color-crimson)' } = Astro.props;
const clamped = Math.max(0, Math.min(100, level));
---

<div class="power-bar">
	<div class="power-bar__label">
		<span>{label}</span>
		<span class="power-bar__value">{clamped}%</span>
	</div>
	<div class="power-bar__track">
		<div class="power-bar__fill" style={`width: ${clamped}%; background-color: ${color};`}>
		</div>
	</div>
</div>

<style>
	.power-bar {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.power-bar__label {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		font-family: var(--font-display);
		letter-spacing: 0.02em;
		font-size: 1.15rem;
		color: var(--color-ink);
	}

	.power-bar__value {
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.8rem;
		color: var(--color-caption);
	}

	.power-bar__track {
		position: relative;
		height: 1.5rem;
		background: var(--color-paper);
		border: 3px solid var(--color-ink);
		/* Hand-drawn wobble: mismatched corner radii instead of a clean rectangle,
		   like the outline was sketched in pencil rather than ruled. */
		border-radius: 7px 4px 8px 3px / 4px 8px 3px 7px;
	}

	.power-bar__fill {
		position: absolute;
		inset: 3px;
		right: auto;
		/* Crayon-fill texture: a rough diagonal hatch rather than a flat color block. */
		background-image: repeating-linear-gradient(
			45deg,
			transparent 0 4px,
			rgb(0 0 0 / 14%) 4px 6px
		);
		border-radius: 5px 2px 6px 1px / 2px 6px 1px 5px;
	}
</style>
