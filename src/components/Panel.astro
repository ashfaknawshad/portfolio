---
interface Props {
	/** Slight hand-placed tilt, in degrees. Positive tilts clockwise. */
	rotate?: number;
	/** Whether to apply the default panel padding. Set false for edge-to-edge content like images. */
	padding?: boolean;
	/** HTML tag to render — use 'article' for standalone content like a project card. */
	as?: string;
	class?: string;
	/** Any extra attributes (e.g. data-reveal, style with --reveal-i) are forwarded
	 * onto the panel root. */
	[key: string]: unknown;
}

const {
	rotate = 0,
	padding = true,
	as: Tag = 'div',
	class: className,
	style: styleProp,
	...rest
} = Astro.props;

// Merge our own --panel-rotate with any incoming style (e.g. a reveal --reveal-i),
// since a raw {...rest} spread of `style` would clobber the rotate.
const style =
	[rotate ? `--panel-rotate: ${rotate}deg` : '', styleProp].filter(Boolean).join('; ') || undefined;
---

<Tag class:list={['panel', className]} style={style} data-padded={padding} {...rest}>
	<slot />
</Tag>

<style>
	.panel {
		position: relative;
		background: var(--color-paper-dim);
		border: 4px solid var(--color-ink);
		box-shadow: 8px 8px 0 var(--color-shadow);
		transform: rotate(var(--panel-rotate, 0deg));
	}

	.panel[data-padded='true'] {
		padding: var(--space-panel);
	}

	@media (prefers-reduced-motion: reduce) {
		.panel {
			transform: none;
		}
	}
</style>
