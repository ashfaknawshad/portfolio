---
// Inlines a self-hosted monochrome SVG (see src/assets/icons/) so its color follows
// the surrounding text via currentColor — an <img src="*.svg"> can't do that, since
// an externally-referenced image is its own isolated document.
const icons = import.meta.glob('../assets/icons/*.svg', {
	eager: true,
	query: '?raw',
	import: 'default',
}) as Record<string, string>;

interface Props {
	name: string;
	size?: string;
	class?: string;
}

const { name, size = '1.1em', class: className } = Astro.props;
const raw = icons[`../assets/icons/${name}.svg`];

if (!raw) {
	throw new Error(`Icon not found: ${name} (expected src/assets/icons/${name}.svg)`);
}
---

<span class:list={['icon', className]} style={`--icon-size: ${size}`} set:html={raw} />

<style>
	.icon {
		display: inline-flex;
		width: var(--icon-size);
		height: var(--icon-size);
		flex-shrink: 0;
	}

	.icon :global(svg) {
		width: 100%;
		height: 100%;
		fill: currentColor;
	}
</style>
