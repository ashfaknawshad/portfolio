---
// A comic "POW/BAM"-style starburst stat callout. The jagged outline is a native SVG
// polygon (fill + stroke), not a CSS clip-path — a clip-path'd div's border only draws
// on the box's original rectangular edges, not the clipped shape, so it can't produce
// a clean outline around a star.
interface Props {
	value: string;
	label: string;
	/** Slight hand-placed tilt, in degrees. */
	rotate?: number;
	/** Varies the spike count/shape and fill colour per instance, and picks the
	 * hover exclamation word, so a row of these doesn't look like one shape
	 * copy-pasted three times. */
	seed?: number;
}

const { value, label, rotate = 0, seed = 0 } = Astro.props;

const SPIKES = 9 + (seed % 3); // 9, 10, 11
const OUTER = 46;
// 34–38: varies the tooth depth a little for visual variety, but not so much that a
// deep-toothed instance (like seed 0 used to be at INNER 30) leaves too little
// horizontal room for the label text before it runs into the points.
const INNER = 36 + ((seed * 4) % 3);

const points = Array.from({ length: SPIKES * 2 }, (_, i) => {
	const angle = (Math.PI / SPIKES) * i - Math.PI / 2;
	const r = i % 2 === 0 ? OUTER : INNER;
	const x = 50 + r * Math.cos(angle);
	const y = 50 + r * Math.sin(angle);
	return `${x.toFixed(2)},${y.toFixed(2)}`;
}).join(' ');

const FILLS = ['var(--color-gold)', 'var(--color-crimson)', 'var(--color-teal)'];
const fill = FILLS[seed % FILLS.length];
const textOnFill = seed % FILLS.length === 0 ? 'var(--color-ink)' : 'var(--color-paper)';

const WORDS = ['POW!', 'BAM!', 'KABOOM!'];
const word = WORDS[seed % WORDS.length];
---

<div
	class="stat-burst"
	style={`--burst-rotate: ${rotate}deg; --burst-fill: ${fill}; --burst-text: ${textOnFill};`}
>
	<svg class="stat-burst__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
		<polygon points={points} class="stat-burst__shape" />
	</svg>
	<div class="stat-burst__content">
		<span class="stat-burst__value">{value}</span>
		<span class="stat-burst__label">{label}</span>
	</div>
	<span class="stat-burst__pow" aria-hidden="true">{word}</span>
</div>

<style>
	.stat-burst {
		position: relative;
		width: clamp(10.5rem, 30vw, 13.5rem);
		aspect-ratio: 1;
		flex-shrink: 0;
		transform: rotate(var(--burst-rotate, 0deg));
		transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	@media (min-width: 700px) {
		/* Wider and flatter on desktop — the SVG polygon is drawn in a normalized
		   100x100 square and stretched via preserveAspectRatio="none", so widening
		   the box here stretches the star into an elliptical shape for free,
		   without touching the point math. */
		.stat-burst {
			width: clamp(13rem, 20vw, 16rem);
			aspect-ratio: 1.5;
		}
	}

	/* The hover "explosion": a quick pop-and-wobble on the whole burst, plus a
	   comic exclamation word that punches in from the corner. */
	.stat-burst:hover {
		transform: rotate(calc(var(--burst-rotate, 0deg) * -1.4)) scale(1.14);
	}

	.stat-burst__svg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		filter: drop-shadow(3px 4px 0 var(--color-shadow));
	}

	.stat-burst__shape {
		fill: var(--burst-fill);
		stroke: var(--color-ink);
		stroke-width: 2.5;
		stroke-linejoin: round;
		transition: fill 0.2s ease;
	}

	.stat-burst__content {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 0.65rem;
	}

	.stat-burst__value {
		font-family: var(--font-display);
		font-size: clamp(1.3rem, 6vw, 2rem);
		line-height: 1;
		color: var(--burst-text);
	}

	.stat-burst__label {
		font-family: var(--font-body);
		font-weight: 600;
		font-size: clamp(0.5rem, 2.3vw, 0.66rem);
		line-height: 1.15;
		letter-spacing: 0.01em;
		text-transform: uppercase;
		color: var(--burst-text);
		margin-top: 0.3rem;
		max-width: 90%;
	}

	.stat-burst__pow {
		position: absolute;
		top: -0.7rem;
		right: -0.9rem;
		font-family: var(--font-display);
		font-size: 1.05rem;
		letter-spacing: 0.02em;
		color: var(--color-crimson);
		background: var(--color-paper);
		border: 2px solid var(--color-ink);
		border-radius: 999px;
		padding: 0.15em 0.55em;
		transform: rotate(-14deg) scale(0);
		opacity: 0;
		transition:
			transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
			opacity 0.2s ease;
		pointer-events: none;
		z-index: 2;
	}

	.stat-burst:hover .stat-burst__pow {
		transform: rotate(-14deg) scale(1);
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.stat-burst,
		.stat-burst__pow {
			transition: none;
		}

		.stat-burst:hover {
			transform: rotate(var(--burst-rotate, 0deg));
		}

		/* No pop/wobble, but the word should still appear on hover, just without
		   the spring animation. */
		.stat-burst:hover .stat-burst__pow {
			transform: rotate(-14deg) scale(1);
			opacity: 1;
		}
	}
</style>
