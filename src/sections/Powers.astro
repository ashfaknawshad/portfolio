---
import Panel from '../components/Panel.astro';
import PowerBar from '../components/PowerBar.astro';
import SkillBadge from '../components/SkillBadge.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import SectionAtmosphere from '../components/SectionAtmosphere.astro';
import { skillCategories, mathTopics } from '../data/skills';
---

<section class="powers" id="issue-2">
	<SectionAtmosphere kind="dots" />
	<!-- Shared hand-inked wobble filter for the category icons — defined once,
	     referenced via filter: url(#ink-wobble) in CategoryIcon.astro. -->
	<svg width="0" height="0" style="position: absolute;" aria-hidden="true">
		<defs>
			<filter id="ink-wobble" x="-20%" y="-20%" width="140%" height="140%">
				<feTurbulence type="fractalNoise" baseFrequency="0.045" numOctaves="2" seed="7" result="n" />
				<feDisplacementMap in="SourceGraphic" in2="n" scale="2.2" xChannelSelector="R" yChannelSelector="G" />
			</filter>
		</defs>
	</svg>

	<header class="powers__header">
		<span class="powers__eyebrow" data-reveal="rise">Issue #2: The Powers</span>
		<h2 class="powers__title" data-reveal="pop">SKILL TREE</h2>
	</header>

	<div class="powers__grid">
		{
			skillCategories.map((category, i) => (
				<Panel
					rotate={i % 2 === 0 ? -0.6 : 0.6}
					class="skill-column"
					data-reveal="fall"
					style={`--reveal-i: ${i}`}
				>
					<div class="skill-column__icon">
						<CategoryIcon slug={category.slug} />
					</div>
					<h3 class="skill-column__title">{category.title}</h3>
					<div class="skill-column__tags">
						{category.skills.map((skill) => (
							<SkillBadge name={skill.name} icon={skill.icon} learning={skill.learning} />
						))}
					</div>
				</Panel>
			))
		}
	</div>

	<Panel rotate={-0.4} class="powers__math" data-reveal="fall">
		<h3 class="powers__math-title">Pure Mathematics</h3>
		<p class="powers__math-note">
			Applied math is fine. Pure math is the addiction — calculus, algebra, statistics,
			the works.
		</p>
		<div class="powers__bars">
			{mathTopics.map((topic) => <PowerBar label={topic.name} level={topic.level} />)}
		</div>
	</Panel>
</section>

<style>
	.powers {
		position: relative;
		isolation: isolate; /* stacking context for the SectionAtmosphere layer */
		padding: var(--space-panel);
		max-width: 72rem;
		margin: 0 auto;
	}

	.powers__header {
		text-align: center;
		margin-bottom: clamp(2rem, 5vw, 3rem);
	}

	.powers__eyebrow {
		display: block;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-teal);
		margin-bottom: 0.5rem;
	}

	.powers__title {
		margin: 0;
	}

	.powers__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(2rem, 5vw, 2.5rem);
		margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
	}

	.skill-column {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.skill-column__icon {
		width: 4rem;
		height: 4rem;
		margin-bottom: 1rem;
	}

	.skill-column__title {
		font-size: 1.3rem;
		margin: 0 0 1rem;
	}

	.skill-column__tags {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
	}

	.powers__math-title {
		font-family: var(--font-display);
		color: var(--color-crimson);
		text-shadow: 0.06em 0.06em 0 var(--color-ink);
		font-size: 1.4rem;
		margin: 0 0 1rem;
	}

	.powers__math-note {
		font-family: var(--font-body);
		color: var(--color-caption);
		margin: 0 0 1.5rem;
		max-width: 34rem;
	}

	.powers__bars {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		max-width: 28rem;
	}

	@media (min-width: 700px) {
		.powers__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1100px) {
		.powers__grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
