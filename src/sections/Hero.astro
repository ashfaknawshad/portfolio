---
import { Image } from 'astro:assets';
import heroCover from '../assets/images/hero-cover.png';
---

<section class="hero" id="issue-1">
	{/* Bespoke rays (not the shared SectionAtmosphere) so the spin centre can sit behind
	    the cover image's own painted sunburst. Full-bleed width, but clipped to the hero's
	    own height so it can't leak into Issue #2 below. */}
	<div class="hero__rays" aria-hidden="true"></div>
	<div class="hero__frame">
		<Image
			src={heroCover}
			alt="Comic-style ink illustration of Ashfak Nawshad in a hoodie, holding an open laptop that glows with floating math and physics equations, standing in front of a crimson sunburst halftone background."
			widths={[480, 800, 1200, 1600]}
			sizes="(min-width: 800px) 420px, 100vw"
			loading="eager"
			fetchpriority="high"
			class="hero__image"
		/>
		<div class="hero__masthead">
			<span class="hero__eyebrow">Issue #1: Origin</span>
			<h1 class="hero__title">ASHFAK NAWSHAD</h1>
		</div>
	</div>
	<div class="hero__caption">
		<p class="hero__lede" data-reveal="rise">
			AI student at the University of Moratuwa. Mathematics tutor for the Sri Lankan
			and Edexcel syllabi. Cinephile who reads every frame like a syllabus. This is
			the origin story.
		</p>
	</div>
</section>

<style>
	/* Mobile: webtoon scroll — image full-bleed above the fold, copy stacked below. */
	.hero {
		display: flex;
		flex-direction: column;
		position: relative;
		isolation: isolate; /* stacking context for the .hero__rays layer */
	}

	/* Full-bleed to the viewport width, but only as tall as the hero (overflow: hidden),
	   so the huge rotating rays square can't bleed into Issue #2. The conic square is
	   300vmax so it always blankets the viewport at every rotation angle (no visible ray
	   ends sweeping in and out). On mobile the cover image is full-bleed and opaque, so
	   these rays mostly sit behind it — they're really a desktop flourish around the
	   framed cover. */
	.hero__rays {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50%;
		width: 100vw;
		margin-left: -50vw;
		overflow: hidden;
		z-index: -1;
		pointer-events: none;
	}

	.hero__rays::before {
		content: '';
		position: absolute;
		width: 300vmax;
		height: 300vmax;
		/* Spin centre. Mobile default: roughly the middle of the full-bleed cover. */
		top: 32%;
		left: 50%;
		translate: -50% -50%;
		background: repeating-conic-gradient(
			from 0deg at 50% 50%,
			var(--color-crimson) 0deg 6deg,
			transparent 6deg 12deg
		);
		opacity: 0.05;
		animation: hero-rays-spin 90s linear infinite;
	}

	@keyframes hero-rays-spin {
		to {
			transform: rotate(360deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__rays::before {
			animation: none;
		}
	}

	.hero__frame {
		position: relative;
	}

	.hero__image {
		display: block;
		width: 100%;
		height: auto;
		border-bottom: 4px solid var(--color-ink);
	}

	.hero__masthead {
		position: absolute;
		top: clamp(1rem, 4%, 2rem);
		left: 0;
		right: 0;
		padding: 0 clamp(1.25rem, 6%, 2.5rem);
		text-align: center;
	}

	.hero__eyebrow {
		display: block;
		font-family: var(--font-body);
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		/* Fixed dark ink, not the theme token: this sits on the source image's cream
		   patch, which stays cream regardless of site theme — it must not flip to
		   light text in dark mode like page foreground text would. */
		color: #1a1a1a;
		margin-bottom: 0.5rem;
	}

	.hero__title {
		margin: 0;
		/* Fixed dark ink for the offset duplicate, same reasoning as .hero__eyebrow:
		   this sits on the image's cream patch, not the theme-aware page background. */
		text-shadow: 0.06em 0.06em 0 #1a1a1a;
	}

	.hero__caption {
		padding: var(--space-panel);
		background: var(--color-paper);
	}

	.hero__lede {
		color: var(--color-caption);
		max-width: 34rem;
		margin: 0;
	}

	/* Desktop: side-by-side comic panel grid — the image is its own contained panel,
	   not the mobile treatment stretched. It never exceeds its natural column width. */
	@media (min-width: 800px) {
		.hero {
			flex-direction: row;
			align-items: center;
			justify-content: center;
			gap: clamp(2rem, 5vw, 4rem);
			max-width: 72rem;
			margin: 0 auto;
			padding: clamp(2rem, 5vw, 4rem);
		}

		.hero__frame {
			flex: 0 0 420px;
			width: 420px;
			border: 4px solid var(--color-ink);
			box-shadow: 8px 8px 0 var(--color-shadow);
		}

		/* Desktop: the cover is a fixed 420px frame on the left of the centred row, so
		   move the rays' spin centre left to sit behind the image's painted sunburst
		   (~46% across, ~32% down the frame) instead of the viewport centre. Approximate
		   — it's a 5%-opacity flourish, not a pixel-locked overlay. */
		.hero__rays::before {
			left: calc(50% - 18rem);
			top: 35%;
		}

		.hero__image {
			border-bottom: none;
		}

		.hero__caption {
			flex: 1 1 24rem;
			max-width: 28rem;
			padding: 0;
			background: transparent;
		}

		/* The frame is a fixed 420px column here, not a fluid one — so the title must
		   not keep scaling with the page's viewport width (global --step-h1 is vw-based
		   and assumes its container grows with the page). A fixed size that's known to
		   fit "ASHFAK NAWSHAD" on one line inside this column, at any page width. */
		.hero__title {
			font-size: 3.5rem;
		}
	}
</style>
